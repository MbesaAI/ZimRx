{
  "name": "mbesaai",
  "version": "1.0.0",
  "description": "> **WhatsApp AI Prescription Assistant for Zimbabwe** > > Helping Zimbabwean patients understand their prescriptions, find registered pharmacies, and store their medication records — all through WhatsApp, no app download required.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "seed:medicines": "node src/db/seed/seedMedicines.js",
    "seed:pharmacies": "node src/db/seed/seedPharmacies.js",
    "seed": "npm run seed:medicines && npm run seed:pharmacies"
  },
